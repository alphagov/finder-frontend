<%= render "components/filter_section", {
  **date_facet.section_attributes,
  visually_hidden_heading_prefix: "Filter by",
  change_category: "update-filter text",
  # Note date is the only validated facet, so if there is an error, it'll be here
  open: @search_query.invalid?,
} do %>
  <%= render "govuk_publishing_components/components/date_input", {
    name: "#{date_facet.key}[from]",
    id: "#{date_facet.key}[from]",
    legend_text: "#{date_facet.name} after",
    hint: "For example, 13 12 #{Date.today.year - 3}",
    error_message: date_facet.error_message_from(@search_query),
    data: {
      ga4_section: "#{date_facet.name} after"
    },
    items: [
      {
        name: "day",
        width: 2,
        value: date_facet.user_supplied_from_date[:day],
      },
      {
        name: "month",
        width: 2,
        value: date_facet.user_supplied_from_date[:month],
      },
      {
        name: "year",
        width: 4,
        value: date_facet.user_supplied_from_date[:year],
      }
    ]
  } %>

  <%= render "govuk_publishing_components/components/date_input", {
    name: "#{date_facet.key}[to]",
    id: "#{date_facet.key}[to]",
    legend_text: "#{date_facet.name} before",
    hint: "For example, 21 7 #{Date.today.year - 1}",
    error_message: date_facet.error_message_to(@search_query),
    data: {
      ga4_section: "#{date_facet.name} before"
    },
    items: [
      {
        name: "day",
        width: 2,
        value: date_facet.user_supplied_to_date[:day],
      },
      {
        name: "month",
        width: 2,
        value: date_facet.user_supplied_to_date[:month],
      },
      {
        name: "year",
        width: 4,
        value: date_facet.user_supplied_to_date[:year],
      }
    ]
  } %>
<% end %>
